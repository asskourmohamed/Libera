# ============================================
# ENVIRONNEMENT
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# DATABASE - MongoDB avec Docker
# ============================================
# ⚠️ Utilisez 'mongodb' comme hostname (nom du service dans docker-compose)
MONGODB_URI=mongodb://libera_user:libera_password_123@127.0.0.1:27017/libera?authSource=libera
# ============================================
# JWT - GÉNÉREZ CES CLÉS UNIQUES
# ============================================
# Exécutez : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=8f4e2d1a9b3c7e5f6d8a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=3f7a2b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# REDIS - Avec Docker
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# CLOUDINARY (À configurer plus tard)
# ============================================
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ============================================
# EMAIL (À configurer plus tard)
# ============================================
SENDGRID_API_KEY=votre_sendgrid_key
FROM_EMAIL=noreply@libera.com

# ============================================
# FRONTEND
# ============================================
CLIENT_URL=http://localhost:5173