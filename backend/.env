# ============================================
# ENVIRONNEMENT
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/bookswap

# ============================================
# JWT
# ============================================
JWT_SECRET=super_secret_jwt_key_change_this
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=refresh_token_secret_change_this
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# CLOUDINARY
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# EMAIL (SendGrid)
# ============================================
SENDGRID_API_KEY=your_sendgrid_key
FROM_EMAIL=noreply@bookswap.com

# ============================================
# SERVICES PORTS
# ============================================
AUTH_SERVICE_PORT=5001
BOOK_SERVICE_PORT=5002
EXCHANGE_SERVICE_PORT=5003
NOTIFICATION_SERVICE_PORT=5004

# ============================================
# FRONTEND URL
# ============================================
CLIENT_URL=http://localhost:3000